# Copy to .env.production for local production builds, or set as GitHub Actions secrets.

# Required — pick ONE approach:

# Full API URL (recommended)
VITE_API_BASE_URL=https://server.stelleronline.com/api/v1

# OR server origin only (/api/v1 appended)
# VITE_BACKEND_URL=https://server.stelleronline.com

# / for custom domain (stelleronline.com). Use /steller-erp-frontend-build/ only for github.io subpath.
VITE_BASE_PATH=/

VITE_APP_NAME=Stellar Camera Rentals ERP
