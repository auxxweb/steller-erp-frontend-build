# --- Local development ---
# Full API base URL (no trailing slash). Preferred variable name.
# VITE_API_BASE_URL=http://localhost:5000/api/v1

# Server origin only — /api/v1 is appended automatically if VITE_API_BASE_URL is unset.
# (Set in .env.development for local dev — not in .env, to avoid leaking into production builds.)
# VITE_BACKEND_URL=http://localhost:5000

# Optional: Vite dev-server proxy target (defaults to VITE_BACKEND_URL or localhost:5000)
# VITE_DEV_PROXY_TARGET=http://localhost:5000

# App metadata
VITE_APP_NAME=Stellar Camera Rentals ERP

# Local dev uses base "/". Production GitHub Pages uses /steller-erp-frontend-build/
# VITE_BASE_PATH=/
