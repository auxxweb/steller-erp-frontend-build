{
  "name": "stellar-rentals-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run pwa:assets && vite build",
    "build:pages": "npm run pwa:assets && vite build && node scripts/verify-dist-html.mjs && node scripts/copy-spa-fallback.mjs && node scripts/verify-dist-html.mjs && node scripts/verify-production-build.mjs",
    "publish:docs": "node scripts/publish-to-docs.mjs",
    "preview": "vite preview",
    "preview:pages": "vite preview",
    "lint": "eslint .",
    "pwa:assets": "node scripts/generate-pwa-assets.mjs",
    "verify:build": "node scripts/verify-production-build.mjs",
    "deploy:docs": "npm run build:pages && node scripts/publish-to-docs.mjs",
    "deploy:gh-pages": "npm run build:pages && gh-pages -d dist"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "html5-qrcode": "^2.3.8",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
